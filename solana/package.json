{
  "name": "syndaxia",
  "version": "0.1.0",
  "private": true,
  "description": "Syndaxia Protocol - Decentralized escrow for P2P & B2B commerce",
  "scripts": {
    "lint:fix": "prettier */*.js \"*/**/*{.js,.ts}\" -w",
    "lint": "prettier */*.js \"*/**/*{.js,.ts}\" --check",
    "init-treasury:devnet": "ts-node scripts/init-treasury.ts",
    "init-treasury:mainnet": "ts-node scripts/init-treasury.ts",
    "squads:devnet": "RPC_URL=https://api.devnet.solana.com ts-node scripts/squads-treasury.ts",
    "squads:mainnet": "RPC_URL=https://api.mainnet-beta.solana.com ts-node scripts/squads-treasury.ts",
    "e2e:devnet": "RPC_URL=https://api.devnet.solana.com ts-mocha -p ./tsconfig.json -t 120000 e2e/**/*.ts"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.32.0",
    "@sqds/multisig": "^2.1.4"
  },
  "devDependencies": {
    "@solana/spl-token": "^0.4.0",
    "@types/bn.js": "^5.1.0",
    "@types/chai": "^4.3.0",
    "@types/mocha": "^9.0.0",
    "@types/node": "^20.0.0",
    "chai": "^4.3.4",
    "mocha": "^9.0.3",
    "prettier": "^2.6.2",
    "ts-mocha": "^10.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
